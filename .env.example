# AI — OpenAI primary, Anthropic fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini

ANTHROPIC_API_KEY=

# Supabase — optional; local file fallback used when not set
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vault storage root (local filesystem fallback)
VAULT_ROOT=./vaults

# MCP server identity
MCP_SERVER_NAME=blume
MCP_SERVER_VERSION=1.0.0
